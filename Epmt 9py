import pandas as pd
import matplotlib.pyplot as plt

# create dataframe (real-life data)
df = pd.DataFrame({
    "product": ["Mobile", "Laptop", "Tablet", "Headphones"],
    "sales": [50, 30, 20, 40]
})

print(df)

# plot bar chart
plt.bar(df["product"], df["sales"])
plt.xlabel("Products")
plt.ylabel("Number of Sales")
plt.title("Shop Sales Report")

plt.show()

