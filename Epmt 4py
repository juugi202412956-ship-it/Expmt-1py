#tuple
# Library books

books = (
    "Harry Potter",
    "The Hobbit",
    "The Lord of the Rings",
    "Pride and Prejudice",
    "To Kill a Mockingbird",
    "1984",
    "The Great Gatsby",
    "Moby Dick",
    "The Catcher in the Rye",
    "Jane Eyre",
    "War and Peace",
    "Crime and Punishment",
    "The Alchemist",
    "The Little Prince",
    "Treasure Island"
)


books_list = list(books)


books_list.sort()
print("Sorted list:", books_list)


books_list.reverse()
print("Reversed list:", books_list)


print("Index of Harry Potter:", books.index("Harry Potter"))


print("Count of The Hobbit:", books.count("The Hobbit"))


print("Length:", len(books))


temp_list = books_list.copy()
temp_list.clear()
print("After clear:", temp_list)


books = tuple(books_list)

print("Final tuple:", books)


for book in books:
    print(book)

